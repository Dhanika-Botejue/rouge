	"authors": [
		"Dhanika"
	],
	"contact": {},
	"license": "MIT",
	"icon": "assets/rouge/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"dev.dhanika.rouge.RougeClient"
		]
	},
	"mixins": [
		{
			"config": "rouge.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.15",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	}
}
